  LINK_LIBRARIES = output/libOpenXLSX.a  -lkernel32 -luser32 -lgdi32 -lwinspool -lshell32 -lole32 -loleaut32 -luuid -lcomdlg32 -ladvapi32
  OBJECT_DIR = _deps\openxlsx-build\Tests\CMakeFiles\OpenXLSXTests.dir
  POST_BUILD = cd .
  PRE_LINK = cd .
  TARGET_FILE = output\OpenXLSXTests.exe
  TARGET_IMPLIB = output\libOpenXLSXTests.dll.a
  TARGET_PDB = OpenXLSXTests.exe.dbg


